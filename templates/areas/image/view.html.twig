{% extends 'link-wrapper.html.twig' %}

{% block component %}
    {% set imageEditable = pimcore_image('image') %}
    {% set imageAsset = imageEditable.getImage() %}

    {% if editmode %}
        {{ imageEditable|raw }}
    {% elseif imageAsset %}

    <twig:Ui:Image
        :src="imageAsset.fullPath"
        :alt="imageEditable.alt ?: imageAsset.filename"
        :variantValues="variantValues"
        :additionalClasses="additionalClasses"
    />

    {% endif %}
{% endblock %}