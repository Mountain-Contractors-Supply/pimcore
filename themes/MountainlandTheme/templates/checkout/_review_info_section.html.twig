<article class="card">
    <h3 class="text-xl md:text-2xl font-medium">{{ title }}</h3>
    <div class="review-info-grid">
        {% for item in info_items %}
            <div class="review-info-item">
                <span class="review-label">{{ item.label }}:</span>
                <span>{{ item.value }}</span>
            </div>
        {% endfor %}
    </div>
</article>
