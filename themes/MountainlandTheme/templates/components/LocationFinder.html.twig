<div {{ attributes }} data-controller="locations">
    <!-- Sidebar toggle button for mobile -->
    <button id="sidebar-toggle" data-locations-target="sidebarToggle" aria-label="Toggle filters sidebar">►</button>

    <main class="page-wrapper">
        <div class="layout-wrapper">
            <aside class="sidebar">
                <h1 style="font-family: var(--secondary-font); font-size: 42pt; color: #11175e;">Locations</h1>
                <h2>Find Your Nearest Branch or Shop by Supply</h2>
                <hr class="sidebar-divider" style="width: 800px" />
                <br />

                <twig:FilterBox
                    :productTypes="this.productTypes"
                    :searchTermValue="this.searchInput"
                    :selectedValues="this.selectedFilters"
                    searchTermModel="searchInput"
                    selectedValuesModel="selectedFilters"
                    searchAction="applyFilters"
                    resetAction="resetFilters"
                />
            </aside>

            <twig:LocationMap :map="this.map" style="height: 100%; width: 100%;" id="map-wrapper" />
        </div>

        <div id="sidebar-overlay" data-locations-target="sidebarOverlay"></div>

        <hr style="width: 97%;">

        <h1 id="location-count" class="location-count-heading">
            <span id="filtered-location-count">{{ this.filteredLocations|length }}</span> Locations Near You
        </h1>

        <div class="layout-wrapper">
            <div class="location-list-wrapper">
                <twig:ItemList :items="this.filteredLocations" emptyMessage="No locations match your filters." />

                <br>
                <h2 style="font-family: var(--secondary-font); font-size: 16pt; color: #11175e;">
                    Can't find a location? Call us at <a>_____</a> or contact us <a>here.</a> We're happy to help.
                </h2>
            </div>

            <aside class="sidebar">
                <div style="text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 625px; width: 100%;">                    <h2 style="color: var(--primary-color); font-family: var(--secondary-font); font-size: 50pt; margin: 0; line-height: 1.2;">
                        <span id="state-count-map">__</span> STATES.<br><span id="location-count-map">__</span> LOCATIONS.
                    </h2>
                    <h3 style="color: var(--primary-color); font-family: var(--secondary-font); font-size: 32pt; margin: 0.5rem 0 0 0; line-height: 1.3; white-space: nowrap;">
                        ALL READY TO SERVE YOU!<br>+ FREE DELIVERY
                    </h3>
                    <div style="display: flex; justify-content: center; margin-top: -1.5rem;">
                        <img src="{{ asset(getStoreLogo()) }}" alt="Mountainland Logo" class="header-logo" />
                    </div>
                </div>
            </aside>
        </div>
    </main>
</div>