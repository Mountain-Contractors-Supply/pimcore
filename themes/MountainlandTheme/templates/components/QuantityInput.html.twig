{% set resolvedValue = value|default(1) %}
{% set resolvedMin = min|default(1) %}
{% set resolvedStep = step|default(1) %}
{% set resolvedName = name|default('quantity') %}

<div class="inline-flex items-center overflow-hidden rounded-md border border-gray-300 bg-white focus-within:ring-2 focus-within:ring-blue-500" data-controller="numeric-input">
        <style>
            input[type="number"]::-webkit-inner-spin-button,
            input[type="number"]::-webkit-outer-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }
            input[type="number"] {
                -moz-appearance: textfield;
            }
            .inline-flex[data-controller="numeric-input"] button {
                border-left: none !important;
                border-right: none !important;
            }
            .inline-flex[data-controller="numeric-input"] button:first-child {
                border-right: none !important;
            }
            .inline-flex[data-controller="numeric-input"] button:last-child {
                border-left: none !important;
            }
            .inline-flex[data-controller="numeric-input"] {
                border-radius: 0.375rem;
            }
            .inline-flex[data-controller="numeric-input"] input[type="number"] {
                border: none !important;
            }
        </style>
    <button type="button" class="flex h-10 w-9 items-center justify-center border-r border-gray-300 text-lg text-[var(--primary-color)] transition-colors hover:bg-gray-50" data-action="click->numeric-input#decrease" aria-label="Decrease">−</button>
    <input
        type="number"
        class="h-10 w-11 border-0 bg-transparent px-1 text-center text-sm font-medium text-gray-800 focus:outline-none focus:ring-0"
        name="{{ resolvedName }}"
        {% if id is defined %}id="{{ id }}"{% endif %}
        value="{{ resolvedValue }}"
        min="{{ resolvedMin }}"
        step="{{ resolvedStep }}"
        {% if max is defined %}max="{{ max }}"{% endif %}
        data-numeric-input-target="input"
        data-cart-target="qtyInput"
    />
    <button type="button" class="flex h-10 w-9 items-center justify-center border-l border-gray-300 text-lg text-[var(--primary-color)] transition-colors hover:bg-gray-50" data-action="click->numeric-input#increase" aria-label="Increase">+</button>
</div>
