{% set banner = html_cva(
    base = 'banner-container',
    variants = {
        variant: {
            hero: 'bg-primary text-white',
            default: ''
        }
    },
    defaultVariants = { variant: 'default' }
) %}

<div class="{{ banner.apply({ variant: variant|default('default') })|tailwind_merge }}">
    {% if bannerImage is defined and bannerImage %}
        <img src="{{ bannerImage }}" alt="{{ bannerAlt|default('Banner') }}" class="main-banner"/>
    {% endif %}
    <div class="banner-overlay">
        <div class="banner-content">
            {% if bannerSmallText is defined or bannerTitle is defined %}
                <h1>
                    {% if bannerSmallText is defined %}<span class="banner-small-text">{{ bannerSmallText }}</span><br>{% endif %}
                    {{ bannerTitle|default('') }}
                </h1>
            {% endif %}
            {% block banner_extra %}{% endblock %}
        </div>
    </div>
</div>
