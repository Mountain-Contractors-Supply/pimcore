<turbo-frame id="cart-list-frame"
             data-controller="cart-list"
             data-action="cart:item:removed@document->cart-list#reload">

    <div class="flex flex-col gap-4">
        <div class="grid grid-cols-1 items-start gap-4 lg:grid-cols-[1fr_320px]">
            <div class="flex flex-col gap-2 overflow-y-auto max-h-[calc(100svh-260px)] pr-1">

                {% if cart.items is empty %}
                    <section class="rounded-2xl border border-gray-200 bg-white p-8 text-center shadow-sm">
                        <h2 class="mb-2 text-lg font-semibold text-gray-900">Your cart is empty</h2>
                        <p class="text-sm text-gray-500">There are no items in your cart yet. Use the Quick Add form below or browse products to add items.</p>
                    </section>
                {% else %}
                    {% for item in cart.items %}
                        <twig:Cart:CartItem
                            :productId="item.product.productId"
                            :uom="item.quantityOrdered.uom"
                            :productName="item.product.name"
                            :brandName="item.product.brandName"
                            :productUrl="element_path(item.product, {'uom': item.quantityOrdered.uom})"
                            :price="item.price ?? 0"
                            :quantity="item.quantityOrdered.quantity"
                            :minQuantity="1"
                        />
                    {% endfor %}
                {% endif %}
            </div>

            <div class="sticky top-4">
                <twig:Cart:CartSummary :cart="cart" />
                <a href="#" class="mt-3 block w-fit mx-auto text-sm text-[var(--primary-color)] transition hover:text-[var(--secondary-color)] hover:underline">
                    View Return Policy
                </a>
            </div>
        </div>

        <section class="rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm mb-8">
            <h2 class="mb-3 text-sm font-semibold text-gray-900">Quick Add</h2>
            <div class="flex flex-wrap items-end gap-3">
                <div class="flex flex-col gap-1">
                    <label for="quick-item-input" class="text-xs font-medium text-gray-600">Item # or name</label>
                    <input id="quick-item-input" type="text" placeholder="Enter item # or name"
                           class="rounded-lg border border-gray-200 px-3 py-1.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[var(--primary-color)]" />
                </div>
                <div class="flex flex-col gap-1">
                    <label for="quick-qty-input" class="text-xs font-medium text-gray-600">Qty</label>
                    <input id="quick-qty-input" type="number" min="1" value="1"
                           class="w-20 rounded-lg border border-gray-200 px-3 py-1.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-[var(--primary-color)]" />
                </div>
                <button id="quick-add-btn"
                        class="rounded-xl bg-[var(--primary-color)] px-5 py-1.5 text-sm font-semibold text-white transition hover:brightness-110 focus:outline-none focus:ring-2 focus:ring-[var(--primary-color)] focus:ring-offset-2">
                    Add to Cart
                </button>
            </div>
            <p class="mt-2 hidden text-sm text-red-500" id="quick-add-error">Item not found in mock catalog.</p>
        </section>
    </div>
</turbo-frame>
