{# Base layout for Mountainland site #}
<!DOCTYPE html>
<html lang="{{ app.request.locale|slice(0, 2) }}">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {% apply spaceless %}
        {% do pimcore_head_title().prepend(getStoreName()) %}
        {% do pimcore_head_title().setSeparator(' | ') %}

        {% set isLink = false %}

        {% if document is instanceof('\\Pimcore\\Model\\Document\\Link') %}
            {% set isLink = true %}
        {% endif %}

        {% if not isLink and document.getTitle() is not empty %}
            {% do pimcore_head_title().append(document.getTitle()) %}
        {% endif %}
    {% endapply %}

    {% block layout_head_meta %}
        {{ pimcore_head_title() }}
        {{ pimcore_head_meta() }}
    {% endblock %}

    {% block head_stylesheets %}
        {{ pimcore_head_link() }}
    {% endblock %}

    <link rel="stylesheet" href="{{ asset('css/tailwind.css') }}" />
    <link rel="stylesheet" href="{{ asset('css/style.css') }}" />

    {{ importmap('app') }}

    {% block head %}{% endblock %}
</head>
<body data-controller="price-loader availability-loader incart-loader">
    <div
        data-controller="symfony--ux-turbo--mercure-turbo-stream"
        data-symfony--ux-turbo--mercure-turbo-stream-hub-value="{{ app.request.schemeAndHttpHost ~ '/hub' }}"
        data-symfony--ux-turbo--mercure-turbo-stream-topic-value="{{ topic_id() }}"
    ></div>

    <header id="header" data-turbo-permanent>
        {% include 'partials/_header.html.twig' %}
    </header>

    <turbo-frame id="body-frame" data-turbo-action="advance" autoscroll data-autoscroll-block="start" data-autoscroll-behavior="smooth">
        <twig:Ui:HeaderSearchCategoryUpdate />

        <main>
            {% block content %}{% endblock %}
        </main>
    </turbo-frame>

    {{ include('partials/_footer.html.twig') }}
</body>
</html>