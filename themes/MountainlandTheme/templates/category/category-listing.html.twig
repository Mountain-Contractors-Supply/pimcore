{% extends 'default/left-column.html.twig' %}

{% block head %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/style.css') }}" />
    <link rel="stylesheet" href="{{ asset('css/home.css') }}" />
{% endblock %}

{% block left_column %}
    <twig:Category:FilterBox actionPath="{{ app.request.pathinfo }}" turboFrame="category-frame" />
{% endblock %}

{% block main_body %}
{#    <twig:PartFinder />#}

    <twig:Layout:Grid :variantValues="{ cols: '4-Column', gap: 'md' }">
        {% for item in categories.pagination.items %}
            <a 
                href="{{ element_path(item) }}"
                class="division-box group block bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-lg hover:border-blue-200 transition-all duration-200">
                <div class="p-6 flex flex-col items-center text-center h-full">
                    <twig:Ui:Image
                        :src="item.imageRef ? item.imageRef.path : ''"
                        :alt="item.name"
                        class="h-24 w-24 mb-4 shadow-none group-hover:scale-110 transition-transform duration-200"
                    />
                    <p class="text-sm font-semibold text-gray-900 group-hover:text-blue-600">{{ item.name }}</p>
                </div>
            </a>
        {% endfor %}
    </twig:Layout:Grid>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <twig:Navigation:PaginationControls
            :pagination="categories.pagination"
            :limit="app.request.query.get('limit', 10)"
        />
    </div>

{% endblock %}
