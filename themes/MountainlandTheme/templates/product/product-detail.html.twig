{% extends 'default/full-width.html.twig' %}

{% block main_body %}
<div class="bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
{#        <twig:AlertBanner message="*Pricing has been adjusted based on your Job Quote" icon="var/assets/images/misc/flag.webp" />#}

        <div class="grid grid-cols-1 lg:grid-cols-[400px_1fr] gap-8 items-start">
            <twig:Ui:Image :alt="product.name|default('Product image')" />

            <twig:Card variant="outlined" class="space-y-4">
                {% set accordionItems = [] %}

                {% if product.description %}
                    {% set accordionItems = accordionItems|merge([{
                        title: 'Description',
                        content: product.description,
                        open: true
                    }]) %}
                {% endif %}
                {% if product.features %}
                    {% set accordionItems = accordionItems|merge([{ title: 'Product Highlights', content: product.features }]) %}
                {% endif %}

                {% set width = product.width is defined ? product.width : null %}
                {% set length = product.length is defined ? product.length : null %}
                {% set height = product.height is defined ? product.height : null %}
                {% set weight = product.weight is defined ? product.weight : null %}

                {% if width is not null or length is not null or height is not null or weight is not null %}
                    {% set dimensionsList = [] %}
                    {% if width is not null %}
                        {% set dimensionsList = dimensionsList|merge(['Width: ' ~ width]) %}
                    {% endif %}
                    {% if length is not null %}
                        {% set dimensionsList = dimensionsList|merge(['Length: ' ~ length]) %}
                    {% endif %}
                    {% if height is not null %}
                        {% set dimensionsList = dimensionsList|merge(['Height: ' ~ height]) %}
                    {% endif %}
                    {% if weight is not null %}
                        {% set dimensionsList = dimensionsList|merge(['Weight: ' ~ weight]) %}
                    {% endif %}
                    {% set accordionItems = accordionItems|merge([{
                        title: 'Specifications',
                        list: dimensionsList
                    }]) %}
                {% endif %}

                {% set contactsList = [] %}
                {% if contactsList|length > 0 %}
                    {% set accordionItems = accordionItems|merge([{
                        title: 'Contact',
                        list: contactsList
                    }]) %}
                {% endif %}

                <div class="space-y-4">
                    <h1 class="text-2xl font-bold mcs-primary-text">{{ product.name|default('Product Name') }}</h1>

                    <twig:Product:ProductPrice
                        :productId="product.productId"
                        :uom="uom"
                    />

                    <div data-controller="cart" data-cart-product-id-value="{{ product.productId }}" data-cart-uom-value="{{ uom }}">
                        <div class="my-4 space-y-3">
                            <div class="flex items-center gap-2">
                                <twig:Form:QuantityInput :value="1" :min="1" name="quantity" data-cart-target="qtyInput" />

                                <twig:Product:ProductAvailability
                                    :productId="product.productId"
                                    :uom="uom"
                                    :inline="true"
                                />
                            </div>

                            <div class="flex items-stretch gap-3 flex-nowrap">
                                <twig:Product:ProductAddToCart
                                    :productId="product.productId"
                                    :uom="uom"
                                    text="Add to Cart"
                                />
                                <twig:Product:ProductAddToList />
                            </div>
                        </div>
                    </div>

                    <div class="space-y-3 py-4 border-y border-gray-200">
                        <twig:Ui:Label label="Item #:" :value="product.productId|default(null)" :showWhenEmpty="true" />
                        <twig:Ui:Label label="UPC:" :value="product.upc|default(null)" />
                        <twig:Ui:Label label="Model #:" :value="product.modelNumber|default(null)" />
                    </div>

                    <twig:Accordion :items="accordionItems" />
                </div>

                <div class="mt-6 border border-gray-200 rounded-lg overflow-hidden">
                    <a href="/calculator" class="flex items-center gap-4 p-4 hover:bg-gray-50 transition" aria-label="Open calculator">
                        <img src="{{ asset('var/assets/images/misc/calculator.webp') }}" alt="Calculator" class="w-12 h-12" />
                        <div>
                            <div class="text-sm text-gray-500 uppercase tracking-wide">Need Help Calculating?</div>
                            <div class="text-lg font-semibold text-gray-900">Use our online calculator</div>
                        </div>
                    </a>
                </div>
            </twig:Card>
        </div>
    </div>

    <twig:Product:ProductUpsell title="You May Also Need..." :products="productsUpsell ?? []" />

    <twig:Product:ProductFaq :faqs="faqs ?? []" />
</div>
{% endblock %}