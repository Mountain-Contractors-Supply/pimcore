{# Homepage template for Mountainland, converted from index.html #}
{% extends 'layout.html.twig' %}

{% block head %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/home.css') }}" />
{% endblock %}

{% block main_content %}
    <div data-controller="home">
        <div class="banner-container">
            <img src="{{ asset('var/assets/images/branding/mls-darren.webp') }}" alt="Mountainland Supply Banner" class="main-banner"/>
            <div class="banner-overlay">
                <div class="banner-content">
                    <h1><span class="banner-small-text">Together, Let's</span><br>MOVE MTNS.</h1>
                </div>
            </div>
        </div>

        {{ pimcore_areablock("defaultAreaBrick") }}

        <div class="family-container">
            <div class="family-section">
                <h1>Part of the Family?</h1>
                <a href="{{ path('customer_signin') }}"><h3>SIGN IN OR REQUEST ONLINE ACCESS</h3></a>
            </div>
            <div class="family-section">
                <h1>Joining the Family?</h1>
                <a href="#"><h3>GET STARTED & SIGN UP TODAY!</h3></a>
            </div>
        </div>

        <div class="divisions-container">
            <img src="{{ asset('images/branding/divisions.webp') }}" alt="{{ productTypes|length }} DIVISIONS BUILT TO SERVE YOU"/>
            <div class="divisions-grid" data-home-target="divisionsGrid">
                {% for productType in productTypes %}
                    <div class="division-box{% if loop.index > 8 %} hidden{% endif %}"{% if productType.image %} style="background-image:url('{{ asset(productType.image) }}');"{% endif %}>
                        <div class="division-box-content"><h3>{{ productType.name }}</h3><hr><p class="shop-now">Shop Now</p></div>
                    </div>
                {% endfor %}
            </div>
            <div class="view-toggle-container">
                <button class="view-toggle-btn" data-home-target="viewToggleBtn" data-action="click->home#toggleDivisions">VIEW MORE ▼</button>
            </div>
        </div>

        <section class="locations-cta-section">
            <div class="locations-cta-container">
                <div class="locations-info">
                    <div class="locations-count">
                        <div>{{ branchSummary.stateCount }} STATES,</div>
                        <div>{{ branchSummary.branchCount }} LOCATIONS.</div>
                    </div>
                    <div class="work-together">LET'S WORK TOGETHER</div>
                </div>
                <div class="location-finder">
                    {% set locationsDoc = pimcore_document_by_path('/locations') %}
                    <a href="{{ locationsDoc ? locationsDoc.getHref() : '/locations' }}" class="location-btn-link">
                        <img src="{{ asset('images/misc/location-button.webp') }}" alt="Find Location">
                        <p class="location-btn-text">CLICK TO FIND A LOCATION NEAR YOU</p>
                    </a>
                </div>
            </div>
        </section>

        <section class="events-section">
            <div class="events-container">
                <img src="{{ asset('images/branding/events.webp') }}" alt="Mountainland Events" class="events-image">
                <div class="events-content">
                    <div class="events-box">
                        <h2 id="events-title" data-home-target="eventsTitle">MOUNTAINLAND EVENTS</h2>
                        <div class="events-arrow">
                            <span class="arrow-bar" id="events-bar" data-home-target="eventsBar" aria-hidden="true"></span>
                            <span class="arrow-head" aria-hidden="true">→</span>
                        </div>
                    </div>
                    <p class="events-tagline">Because Every Project Starts ― and Ends ― with You.</p>
                </div>
            </div>
        </section>

        <section class="expert-section">
            <div class="expert-container">
                <div class="expert-image-container">
                    <img src="{{ asset('images/misc/text-an-expert.webp') }}" alt="Text an Expert">
                </div>
                <div class="expert-boxes-grid">
                    <div class="expert-box" data-home-target="expertBox" data-action="click->home#toggleExpertBox">
                        <div class="expert-box-content">
                            <h3>PLUMBING</h3>
                            <div class="expert-box-dropdown"><p>Placeholder</p></div>
                        </div>
                    </div>
                    <div class="expert-box" data-home-target="expertBox" data-action="click->home#toggleExpertBox">
                        <div class="expert-box-content">
                            <h3>HVAC</h3>
                            <div class="expert-box-dropdown"><p>Placeholder</p></div>
                        </div>
                    </div>
                    <div class="expert-box" data-home-target="expertBox" data-action="click->home#toggleExpertBox">
                        <div class="expert-box-content">
                            <h3>PUMP & DRILLING</h3>
                            <div class="expert-box-dropdown"><p>Placeholder</p></div>
                        </div>
                    </div>
                    <div class="expert-box" data-home-target="expertBox" data-action="click->home#toggleExpertBox">
                        <div class="expert-box-content">
                            <h3>WATERWORKS</h3>
                            <div class="expert-box-dropdown"><p>Placeholder</p></div>
                        </div>
                    </div>
                    <div class="expert-box" data-home-target="expertBox" data-action="click->home#toggleExpertBox">
                        <div class="expert-box-content">
                            <h3>TURF IRRIGATION</h3>
                            <div class="expert-box-dropdown"><p>Placeholder</p></div>
                        </div>
                    </div>
                    <div class="expert-box" data-home-target="expertBox" data-action="click->home#toggleExpertBox">
                        <div class="expert-box-content">
                            <h3>AG IRRIGATION</h3>
                            <div class="expert-box-dropdown"><p>Placeholder</p></div>
                        </div>
                    </div>
                    <div class="expert-box" data-home-target="expertBox" data-action="click->home#toggleExpertBox">
                        <div class="expert-box-content">
                            <h3>ESPAÑOL</h3>
                            <div class="expert-box-dropdown"><p>Placeholder</p></div>
                        </div>
                    </div>
                    <div class="expert-box" data-home-target="expertBox" data-action="click->home#toggleExpertBox">
                        <div class="expert-box-content">
                            <h3>ORDER NOW</h3>
                            <div class="expert-box-dropdown"><p>Placeholder</p></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {# Temporary #}
        <twig:Ui:ImageWithText
            src="images/misc/camera.webp"
            alt="Our team"
            heading="About Us"
            body="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Etiam a nunc luctus, pellentesque nisl vel, fringilla magna. Suspendisse pulvinar erat a ligula feugiat scelerisque in a metus. Donec eleifend non lacus sed posuere. Nullam congue eu mauris et pellentesque. Ut pharetra, lorem nec lacinia mollis, sapien leo faucibus quam, vel consectetur velit justo nec odio. Sed vel rutrum nunc, sed iaculis justo. Mauris commodo pharetra tortor, in placerat ipsum. Nunc dignissim nulla orci, eget luctus leo tincidunt a. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer varius turpis eget neque laoreet laoreet. In purus diam, convallis a varius vitae, hendrerit vitae sapien. Fusce dictum aliquet dolor sed aliquet.

