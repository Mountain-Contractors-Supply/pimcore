{# Homepage template for Mountainland, converted from index.html #}
{% extends 'layout.html.twig' %}

{% block head %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/home.css') }}" />
{% endblock %}

{% block content %}
    <div data-controller="home">

        <twig:Ui:Banner
            variant="hero"
            bannerImage="{{ asset('var/assets/images/branding/mls-darren.webp') }}"
            bannerAlt="Mountainland Supply Banner"
            bannerSmallText="Together, Let's"
            bannerTitle="MOVE MTNS."
        />

        {% set family_left %}
            <h1>Part of the Family?</h1>
            <a href="{{ path('customer-signin') }}"><h3>SIGN IN OR REQUEST ONLINE ACCESS</h3></a>
        {% endset %}

        {% set family_right %}
            <h1>Joining the Family?</h1>
            <a href="#"><h3>GET STARTED & SIGN UP TODAY!</h3></a>
        {% endset %}

        <twig:Layout:TwoColumn leftColumn="{{ family_left|raw }}" rightColumn="{{ family_right|raw }}" class="family-container" left_class="family-section p-6 text-white" right_class="family-section p-6 text-white" />

        <div class="divisions-container">
            <twig:Ui:Image :src="asset('images/branding/divisions.webp')" alt="{{ productTypes|length }} DIVISIONS BUILT TO SERVE YOU" wrapper_class="aspect-auto w-full bg-transparent shadow-none" img_class="w-full h-auto object-cover p-0" />
                <div class="divisions-grid grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6" data-home-target="divisionsGrid">
                {% for productType in productTypes %}
                    {% set divisionContent %}
                        <h3 class="text-sm font-semibold">{{ productType.name }}</h3>
                        <hr class="my-2 border-t-2 border-white/90" />
                        <p class="shop-now font-semibold text-white text-sm mt-1">Shop Now</p>
                    {% endset %}

                    <twig:Box variant="division" :title="productType.name" :content="divisionContent" :image="productType.image ? asset(productType.image) : null" :index="loop.index" :visibleCount="8" wrapper_class="division-box" content_class="division-box-content" />
                {% endfor %}
            </div>
            <div class="view-toggle-container">
                <twig:Button variant="view-more" data-home-target="viewToggleBtn" data-action="click->home#toggleDivisions">VIEW MORE ▼</twig:Button>
            </div>
        </div>

        <section class="events-section">
            {% set events_left %}
                <twig:Ui:Image :src="asset('images/branding/events-hero.webp')" alt="Mountainland Events" wrapper_class="w-full h-full bg-cover bg-center rounded-lg" img_class="w-full h-full object-cover" />
            {% endset %}

            {% set events_right %}
                <div class="flex flex-col justify-center px-6 md:px-12 lg:px-24">
                    <div class="border-4 border-white p-6 md:p-12 text-center cursor-pointer transition-transform duration-300 hover:scale-105 w-full">
                        <h2 class="font-secondary text-3xl md:text-5xl text-white font-bold mb-6">MOUNTAINLAND EVENTS</h2>
                        <div class="flex items-center w-full relative">
                            <span class="block h-1 bg-gradient-to-r from-white/30 via-white/75 to-white flex-1 mr-0" aria-hidden="true"></span>
                            <span class="text-white text-[52px] md:text-[60px] font-bold -ml-3 -translate-y-[1.575px] md:-translate-y-[2.575px]" aria-hidden="true">→</span>
                        </div>
                    </div>
                    <p class="text-white text-xl italic font-light text-center mt-6">Because Every Project Starts ― and Ends ― with You.</p>
                </div>
            {% endset %}

            <div class="w-screen -mx-4 sm:-mx-6 lg:-mx-8 bg-primary">
                <div class="max-w-none mx-auto">
                    <twig:Layout:TwoColumn leftColumn="{{ events_left|raw }}" rightColumn="{{ events_right|raw }}" class="" />
                </div>
            </div>
        </section>

        <section class="locations-cta-section">
            <div class="locations-cta-container">
                <div class="locations-info">
                    <div class="locations-count">
                        <div>{{ branchSummary.stateCount }} STATES,</div>
                        <div>{{ branchSummary.branchCount }} LOCATIONS.</div>
                    </div>
                    <div class="work-together">LET'S WORK TOGETHER</div>
                </div>
                <div class="location-finder">
                    {% set locationsDoc = pimcore_document_by_path('/locations') %}
                    <a href="{{ locationsDoc ? locationsDoc.getHref() : '/locations' }}" class="location-btn-link">
                        <twig:Ui:Image :src="asset('images/misc/location-button.webp')" alt="Find Location" wrapper_class="w-auto bg-transparent shadow-none" img_class="w-auto h-auto object-contain p-0" />
                        <p class="location-btn-text">CLICK TO FIND A LOCATION NEAR YOU</p>
                    </a>
                </div>
            </div>
        </section>

        <section class="expert-section w-full bg-transparent">
            <div class="expert-inner flex flex-col md:flex-row md:items-start md:space-x-8 w-full">
                <div class="expert-image-container md:w-1/3 mb-6 md:mb-0">
                    <twig:Ui:Image :src="asset('images/misc/text-an-expert.webp')" alt="Text an Expert" wrapper_class="w-full bg-transparent shadow-none" img_class="w-full h-auto object-contain p-0" />
                </div>

                <div class="md:flex-1">
                    <div class="expert-boxes-wrapper max-w-6xl mx-auto px-4">
                        <div class="expert-boxes-grid md:flex-1 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                            {% for title in ['PLUMBING','HVAC','PUMP & DRILLING','WATERWORKS','TURF IRRIGATION','AG IRRIGATION','ESPAÑOL','ORDER NOW'] %}
                                <twig:Box variant="expert" :title="title" wrapper_class="expert-box" content_class="expert-box-content" />
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </section>
{% endblock %}