{# Homepage template for Mountainland, converted from index.html #}
{% extends 'layout.html.twig' %}

{% block head %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/home.css') }}" />
{% endblock %}

{% block content %}
    <div data-controller="home">

        <twig:Ui:Banner
            variant="hero"
            bannerImage="{{ asset('var/assets/images/branding/mls-darren.webp') }}"
            bannerAlt="Mountainland Supply Banner"
            bannerSmallText="Together, Let's"
            bannerTitle="MOVE MTNS."
        />

        <twig:FamilyCTA
            left_title="Part of the Family?"
            left_href="{{ path('customer-signin') }}"
            left_cta="SIGN IN OR REQUEST ONLINE ACCESS"
            right_title="Joining the Family?"
            right_href="#"
            right_cta="GET STARTED & SIGN UP TODAY!"
        />

        <div class="divisions-container">
            <twig:Ui:Image :src="asset('images/branding/divisions.webp')" alt="{{ productTypes|length }} DIVISIONS BUILT TO SERVE YOU" wrapper_class="aspect-auto w-full bg-transparent shadow-none" img_class="w-full h-auto object-cover p-0" />
            <div class="divisions-grid" data-home-target="divisionsGrid">
                {% for productType in productTypes %}
                    <twig:Box :title="productType.name" :image="productType.image ? asset(productType.image) : null" :index="loop.index" :visibleCount="8" wrapper_class="division-box" content_class="division-box-content" />
                {% endfor %}
            </div>
            <div class="view-toggle-container">
                <twig:Button variant="view-more" data-home-target="viewToggleBtn" data-action="click->home#toggleDivisions">VIEW MORE ▼</twig:Button>
            </div>
        </div>

        <section class="locations-cta-section">
            <div class="locations-cta-container">
                <section class="expert-section">
                    <div class="expert-container max-w-6xl mx-auto px-4">
                        <div class="expert-inner flex flex-col md:flex-row md:items-start md:space-x-8">
                            <div class="expert-image-container md:w-1/3 mb-6 md:mb-0">
                                <twig:Ui:Image :src="asset('images/misc/text-an-expert.webp')" alt="Text an Expert" wrapper_class="w-auto bg-transparent shadow-none" img_class="w-full h-auto object-contain p-0" />
                            </div>

                            <div class="md:flex-1">
                                <div class="expert-boxes-grid md:flex-1">
                                    {% for title in ['PLUMBING','HVAC','PUMP & DRILLING','WATERWORKS','TURF IRRIGATION','AG IRRIGATION','ESPAÑOL','ORDER NOW'] %}
                                        <twig:Box :title="title" wrapper_class="expert-box" content_class="expert-box-content" />
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
    </div>
{% endblock %}